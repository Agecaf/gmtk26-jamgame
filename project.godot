; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GMTK26 Jam Game"
run/main_scene="uid://b4enwwndlpugd"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://assets/art/icon.svg"

[audio]

buses/default_bus_layout="uid://blvcceoo7rnvg"

[autoload]

Enums="*uid://huyqiws3vxxr"
Debug="*uid://l5tn6thxg13w"
Game="*uid://bucp3jqx788lh"
Audio="*uid://4elc3l3j71v4"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="viewport"

[file_customization]

folder_colors={
"res://assets/": "yellow",
"res://game/": "red",
"res://levels/": "orange",
"res://menu/": "green",
"res://scripts/": "purple",
"res://test/": "teal"
}

[layer_names]

2d_physics/layer_1="Player"
2d_physics/layer_3="Traps"
2d_physics/layer_4="Projectiles"
2d_physics/layer_17="Ground/Walls"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

